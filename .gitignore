# === Python & Environments ===
__pycache__/
*.py[cod]
.venv/
env/
.ipynb_checkpoints/

# Alternatively, if you want to keep the FOLDERS but ignore ALL data inside them:
# [Remove the line above and use these instead:]
0*/
!0*/.gitkeep

# === Delta Lake & Spark Metadata (Global) ===
# This catches logs/metadata at any depth in your project
**/_delta_log/
**/_checkpoints/
**/_staged_commits/
**/_SUCCESS
**/.crc
**/*.part-*

# === Specific Data Formats ===
*.parquet
*.csv
*.json
# Keep your actual source code JSONs if necessary:
# !config.json

# === IDE & OS ===
.vscode/
.idea/
.DS_Store
*.log